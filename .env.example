# =============================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================
PORT=5000
NODE_ENV=production

# =============================================
# BASE DE DATOS
# =============================================
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/herramientas_taller?retryWrites=true&w=majority

# =============================================
# AUTENTICACIÓN
# =============================================
JWT_SECRET=genera-una-cadena-aleatoria-muy-larga-aqui

# =============================================
# EMAIL (Gmail)
# =============================================
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=tu-app-password-de-gmail

# =============================================
# CORS — URL del frontend
# Soporta múltiples orígenes separados por coma
# =============================================
CLIENT_URL=https://tu-app.netlify.app

# =============================================
# CLOUDINARY (storage de imágenes)
# https://console.cloudinary.com → Settings → API Keys
# =============================================
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# =============================================
# SCHEDULER DE NOTIFICACIONES
# =============================================
CRON_SCHEDULE=0 9 * * *
SCHEDULER_TIMEZONE=America/Mexico_City

# =============================================
# REGLAS DE NEGOCIO
# =============================================
MAX_LOAN_DAYS=5
REMIND_AFTER_DAYS=3
