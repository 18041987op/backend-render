# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — Plantilla de variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=5000

# ── Base de Datos ─────────────────────────────────────────────────────────────
# MongoDB local:
MONGODB_URI=mongodb://localhost:27017/tools_db
# MongoDB Atlas (reemplazar con tu URI real):
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/tools_db

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. Genera uno en: https://generate-secret.vercel.app/32
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_de_minimo_32_chars

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Usa una App Password de Google, no la contraseña real de tu cuenta.
# Cómo obtenerla: Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
FROM_NAME=Sistema de Herramientas AutoRx
FROM_EMAIL=tucorreo@gmail.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Desarrollo:  http://localhost:3000
# Producción:  https://tools-op.web.app  (o tu dominio de Firebase Hosting)
# Múltiples orígenes separados por coma: https://tools-op.web.app,https://otro-dominio.com
CLIENT_URL=http://localhost:3000

# ── Firebase Admin SDK (para subida de imágenes) ──────────────────────────────
# Obtén el Service Account en: Firebase Console → Configuración → Cuentas de servicio
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app

# ── Scheduler de Notificaciones ───────────────────────────────────────────────
# Expresión cron que controla con qué frecuencia se verifica el estado de préstamos.
# Producción:  0 9 * * *   → diariamente a las 9 AM
# Desarrollo:  */10 * * * * → cada 10 minutos
CRON_SCHEDULE=0 9 * * *

# Zona horaria para el scheduler (IANA timezone name).
# Consulta la lista completa en: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
SCHEDULER_TIMEZONE=America/Mexico_City
